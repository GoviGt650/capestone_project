{
  "dashboard": {
    "id": null,
    "panels": [
      {
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "mappings": [
              {
                "color": "green",
                "text": "UP",
                "type": "value",
                "value": "1"
              },
              {
                "color": "red",
                "text": "DOWN",
                "type": "value",
                "value": "0"
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 3,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "options": {
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "values": false
          },
          "textMode": "auto"
        },
        "targets": [
          {
            "expr": "max(probe_success{framework=\"fastapi\"})",
            "legendFormat": "FastAPI",
            "refId": "A"
          },
          {
            "expr": "max(probe_success{framework=\"django\"})",
            "legendFormat": "Django",
            "refId": "B"
          },
          {
            "expr": "max(probe_success{framework=\"node\"})",
            "legendFormat": "Node",
            "refId": "C"
          },
